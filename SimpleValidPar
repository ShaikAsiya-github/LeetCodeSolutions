package basic;

public class SimpleTypeParan {
	public static int valPar(String s,int ans) {
		for(char c: s.toCharArray()) {
			if(c=='(') {
				ans+=1;
			}
			if(c== ')') {
				ans-=1;
			}
		}
		return ans;
	}

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		String s= "((())";
		int ans= 0;
		int res = valPar(s, ans);
		System.out.println(res);
		
	}

}
