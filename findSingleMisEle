package basic;

public class FindMissingEle1 {
	public static void main(String args[]) {
		int arr[]= {1,0,2,4};
		int n=arr.length;
		int s=0;
		for(int i=0;i<n;i++) {
			s+=arr[i];
		}
		System.out.println("Sum of array elements is: "+s);
		int res=n*(n+1)/2-s;
		System.out.println("The missing element is "+ res);
		
	}

}
