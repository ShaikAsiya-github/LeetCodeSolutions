public class LinkedList {
    static class Node{
        int value;
        Node next;
        Node(int val){
            this.value= val;
            this.next= null;
        }
    }
    Node head;
    //10, 20, 30
    public void insert(int data){
        Node newNode= new Node(data);
        if(head==null){
            head= newNode;
            return;
        }
        Node temp= head;
        while(temp.next!=null){
            temp= temp.next;
        }
        temp.next= newNode;
    }
    
    
    public void display(){
        Node temp= head; 
        while(temp!=null){
             System.out.print(temp.value +"-> ");
             temp= temp.next;
        }
         System.out.println("null");
        // System.out.println(head);
    }
    public static void main(String[] args) {
        System.out.println("Try programiz.pro");
       LinkedList m= new LinkedList();
        m.insert(10);
        m.insert(20);
        m.insert(30);
        m.insert(40);
        m.display();
        
    }
}
